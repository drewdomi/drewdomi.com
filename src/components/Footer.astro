---
import * as m from '@/paraglide/messages'
import { Image } from 'astro:assets'
---

<footer
  id="site-footer"
  class="flex h-[100px] items-center justify-center gap-2 bg-[var(--color-base-400)] font-light text-white"
>
  <button
    aria-hidden="true"
    id="footer-logo"
    class="cursor-pointer"
  >
    <Image
      src="/red_ace_pride.svg"
      alt="Logo Alternative"
      width="16"
      height="16"
      decoding="async"
      loading="lazy"
    />
  </button>

  <p class="text-xs sm:text-sm">{m.siteCopy}</p>
</footer>

<style>
  p {
    -webkit-user-select: none; /* Safari */
    -ms-user-select: none; /* IE 10 and IE 11 */
    user-select: none; /* Standard syntax */
  }
</style>

<script src="@/utils/confetti"></script>

---
interface Props {
  href: string
  cover: string
  altCover: string
  title: string
  desc: string
}

const { href, cover, altCover, title, desc } = Astro.props
---

<a
  {href}
  class="block"
>
  <img
    class="rounded-md border-0 shadow-md"
    src={cover}
    width="100%"
    alt={altCover}
  />
  <h2 class="font-title mt-4 mb-3 text-center text-xl font-medium">
    {title}
  </h2>
  <p class="text-center text-sm">
    {desc}
  </p>
</a>
